# direnv configuration for flask-backend
# Run 'direnv allow' to enable automatic venv activation

# Create venv if it doesn't exist
if [ ! -d ".venv" ]; then
    echo "🐍 Creating virtual environment..."
    python3 -m venv .venv
    .venv/bin/pip install --upgrade pip -q
    .venv/bin/pip install -r requirements.txt -q
    echo "✅ Virtual environment created!"
fi

# Activate the virtual environment
source .venv/bin/activate

# Set Flask environment variables
export FLASK_APP=app
export FLASK_ENV=development
export FLASK_DEBUG=1

# Database defaults (override in .env.local)
export DB_TYPE="${DB_TYPE:-postgresql}"
export DB_HOST="${DB_HOST:-localhost}"
export DB_PORT="${DB_PORT:-5432}"
export DB_NAME="${DB_NAME:-project_template}"
export DB_USER="${DB_USER:-postgres}"
export DB_PASS="${DB_PASS:-postgres}"

# Load local overrides if present
if [ -f ".env.local" ]; then
    dotenv .env.local
fi

echo "🐍 flask-backend venv activated"
